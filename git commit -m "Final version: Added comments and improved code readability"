#include <iostream>
using namespace std;

int main() {
    // Declare variables for temperature readings
    int temp1, temp2, temp3;

    // Input first reading
    cout << "Enter first temperature: ";
    cin >> temp1;

    // Input second reading
    cout << "Enter second temperature: ";
    cin >> temp2;

    // Calculate temperature difference
    int diff = temp2 - temp1;

    // Validate temperature increase
    if (diff > 50) {
        cout << "Reduce fryer heat before taking the third reading." << endl;
    } else if (diff < 10) {
        cout << "Increase the fryer heat before taking the third reading." << endl;
    }

    // Input third reading
    cout << "Enter third temperature: ";
    cin >> temp3;

    // Check if oil is ready for frying
    if (temp3 >= 150 && temp3 <= 190) {
        cout << "You may start frying the Magwinyas." << endl;
    } else {
        cout << "Oil is not ready for frying!" << endl;
    }

    return 0;
}
